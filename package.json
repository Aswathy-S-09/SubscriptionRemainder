{
  "name": "subscribely-fullstack",
  "version": "1.0.0",
  "description": "Subscribely - Subscription Management Application",
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && npm start",
